# =============================================================================
# Конфигурация для Phi-3-mini с LoRA
# =============================================================================
# Для GPU с 16GB+ VRAM (например, RTX 4090, A100)

# Model
BASE_MODEL_NAME=microsoft/Phi-3-mini-4k-instruct
HF_CACHE_DIR=~/.cache/huggingface
TRUST_REMOTE_CODE=false

# LoRA Configuration (больше rank для сложной модели)
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj
LORA_BIAS=none
LORA_TASK_TYPE=CAUSAL_LM

# Training
OUTPUT_DIR=./outputs/phi3
CHECKPOINT_DIR=./checkpoints/phi3
NUM_EPOCHS=5
PER_DEVICE_BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=8
LEARNING_RATE=1e-4
WARMUP_RATIO=0.03
WEIGHT_DECAY=0.01
MAX_GRAD_NORM=1.0
LOGGING_STEPS=10
SAVE_STEPS=100
EVAL_STRATEGY=steps
EVAL_STEPS=100
LOAD_BEST_MODEL_AT_END=true
SAVE_TOTAL_LIMIT=3

# Data (больший контекст для Phi-3)
TRAIN_DATA_PATH=./data/train.jsonl
INSTRUCTION_COLUMN=instruction
RESPONSE_COLUMN=response
MAX_SEQ_LENGTH=2048

# Optimization (BF16 для Ampere GPU)
FP16=false
BF16=true
GRADIENT_CHECKPOINTING=true

# Logging & Monitoring
LOG_LEVEL=INFO
LOG_FILE=./logs/phi3_training.log
WANDB_PROJECT=phi3-instruction-tuning
