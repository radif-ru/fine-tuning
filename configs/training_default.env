# =============================================================================
# Конфигурация для обучения (Training-only config)
# =============================================================================
# Универсальная конфигурация для различных моделей
# Подходит для CPU/GPU с 8GB+ VRAM

# =============================================================================
# Model Configuration
# =============================================================================
# Имя модели из HuggingFace Hub или локальный путь
BASE_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Кэш директория для моделей
HF_CACHE_DIR=~/.cache/huggingface

# Доверять remote code (для некоторых моделей)
TRUST_REMOTE_CODE=false

# =============================================================================
# LoRA Configuration
# =============================================================================
# Rank матриц LoRA (чем больше, тем больше параметров)
LORA_R=8

# Alpha параметр для масштабирования
LORA_ALPHA=16

# Dropout для регуляризации
LORA_DROPOUT=0.05

# Целевые модули (зависит от архитектуры)
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# Тип bias (none, all, lora_only)
LORA_BIAS=none

# Тип задачи
LORA_TASK_TYPE=CAUSAL_LM

# =============================================================================
# Training Configuration
# =============================================================================
# Директория для результатов
OUTPUT_DIR=./outputs/run-default

# Директория для чекпоинтов
CHECKPOINT_DIR=./checkpoints/run-default

# Количество эпох
NUM_EPOCHS=3

# Batch size на устройство
PER_DEVICE_BATCH_SIZE=4

# Шаги накопления градиента
GRADIENT_ACCUMULATION_STEPS=4

# Learning rate
LEARNING_RATE=2e-4

# Warmup ratio
WARMUP_RATIO=0.03

# Weight decay для регуляризации
WEIGHT_DECAY=0.01

# Max gradient norm для clipping
MAX_GRAD_NORM=1.0

# =============================================================================
# Training Logging & Saving
# =============================================================================
# Логирование каждые N шагов
LOGGING_STEPS=10

# Сохранение чекпоинта каждые N шагов
SAVE_STEPS=100

# Стратегия evaluation (no, steps, epoch)
EVAL_STRATEGY=steps

# Evaluation каждые N шагов
EVAL_STEPS=100

# Загрузить лучшую модель в конце
LOAD_BEST_MODEL_AT_END=true

# Максимум сохранённых чекпоинтов
SAVE_TOTAL_LIMIT=3

# =============================================================================
# Data Configuration
# =============================================================================
# Путь к данным для обучения
TRAIN_DATA_PATH=./data/train.jsonl

# Название колонки с текстом
TEXT_COLUMN=text

# Максимальная длина последовательности
MAX_SEQ_LENGTH=512

# =============================================================================
# Optimization
# =============================================================================
# Использовать FP16 (для GPU с поддержкой)
FP16=true

# Использовать BF16 (для Ampere+ GPU)
BF16=false

# Gradient checkpointing для экономии памяти
GRADIENT_CHECKPOINTING=true

# =============================================================================
# Logging
# =============================================================================
# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Файл для логов
LOG_FILE=./logs/training.log
