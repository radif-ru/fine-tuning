# =============================================================================
# Конфигурация для TinyLlama 1.1B с LoRA
# =============================================================================
# Подходит для CPU/GPU с 8GB VRAM

# Model
BASE_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
HF_CACHE_DIR=~/.cache/huggingface
TRUST_REMOTE_CODE=false

# LoRA Configuration
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.1
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj
LORA_BIAS=none
LORA_TASK_TYPE=CAUSAL_LM

# Training
OUTPUT_DIR=./outputs/tinyllama
CHECKPOINT_DIR=./checkpoints/tinyllama
NUM_EPOCHS=3
PER_DEVICE_BATCH_SIZE=4
GRADIENT_ACCUMULATION_STEPS=4
LEARNING_RATE=2e-4
WARMUP_RATIO=0.03
WEIGHT_DECAY=0.01
MAX_GRAD_NORM=1.0
LOGGING_STEPS=10
SAVE_STEPS=100
EVAL_STRATEGY=steps
EVAL_STEPS=100
LOAD_BEST_MODEL_AT_END=true
SAVE_TOTAL_LIMIT=3

# Data
TRAIN_DATA_PATH=./data/train.jsonl
TEXT_COLUMN=text
MAX_SEQ_LENGTH=512

# Optimization
FP16=true
BF16=false
GRADIENT_CHECKPOINTING=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/tinyllama_training.log
