# =============================================================================
# Конфигурация для GPT-2 с LoRA (для тестирования)
# =============================================================================
# Быстрая конфигурация для быстрого тестирования

# Model
BASE_MODEL_NAME=gpt2
HF_CACHE_DIR=~/.cache/huggingface

# LoRA Configuration
LORA_R=4
LORA_ALPHA=8
LORA_DROPOUT=0.1
LORA_TARGET_MODULES=c_attn,c_proj
LORA_BIAS=none
LORA_TASK_TYPE=CAUSAL_LM

# Training (1 эпоха для быстрых тестов)
OUTPUT_DIR=./outputs/gpt2_test
CHECKPOINT_DIR=./checkpoints/gpt2_test
NUM_EPOCHS=1
PER_DEVICE_BATCH_SIZE=2
GRADIENT_ACCUMULATION_STEPS=2
LEARNING_RATE=5e-4
WARMUP_RATIO=0.0
WEIGHT_DECAY=0.01
MAX_GRAD_NORM=1.0
LOGGING_STEPS=5
SAVE_STEPS=50
EVAL_STRATEGY=no
LOAD_BEST_MODEL_AT_END=false
SAVE_TOTAL_LIMIT=2

# Data
TRAIN_DATA_PATH=./data/train.jsonl
TEXT_COLUMN=text
MAX_SEQ_LENGTH=128

# Optimization
FP16=false
BF16=false
GRADIENT_CHECKPOINTING=false

# Logging
LOG_LEVEL=DEBUG
