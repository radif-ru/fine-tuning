# =============================================================================
# Конфигурация для инференса (Inference-only config)
# =============================================================================
# Настройки для генерации текста с fine-tuned моделями

# =============================================================================
# Model Configuration
# =============================================================================
# Базовая модель из HF Hub или локальный путь
BASE_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Путь к LoRA адаптеру (опционально)
# ADAPTER_PATH=./outputs/run-001/final

# Кэш директория
HF_CACHE_DIR=~/.cache/huggingface

# =============================================================================
# Generation Configuration
# =============================================================================
# Максимальное количество новых токенов
MAX_NEW_TOKENS=256

# Temperature для sampling (> 0)
TEMPERATURE=0.7

# Top-p (nucleus sampling, 0-1)
TOP_P=0.9

# Top-k sampling
TOP_K=50

# Штраф за повторения (1.0 = без штрафа)
REPETITION_PENALTY=1.0

# Использовать sampling (true) или greedy (false)
DO_SAMPLE=true

# =============================================================================
# Inference Configuration
# =============================================================================
# Устройство (auto, cpu, cuda, cuda:0)
INFERENCE_DEVICE=auto

# Загрузить в 8-bit режиме (экономит память)
LOAD_IN_8BIT=false

# Тип данных (float16, bfloat16, float32)
TORCH_DTYPE=float16

# =============================================================================
# Prompt Configuration
# =============================================================================
# Шаблон промптов (alpaca, raw, chat)
PROMPT_TEMPLATE=alpaca

# =============================================================================
# Export Configuration
# =============================================================================
# Путь для сохранения объединённой модели
MERGED_MODEL_OUTPUT_PATH=./outputs/merged-model

# =============================================================================
# Logging
# =============================================================================
# Уровень логирования
LOG_LEVEL=INFO

# Файл для логов инференса
LOG_FILE=./logs/inference.log
