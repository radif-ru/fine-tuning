# =============================================================================
# Конфигурация фреймворка дообучения LLM
# =============================================================================
# Скопируйте этот файл в .env и заполните свои значения
# Никогда не коммитьте .env в систему контроля версий!

# -----------------------------------------------------------------------------
# Конфигурация модели
# -----------------------------------------------------------------------------

# Имя базовой модели из HuggingFace Hub или локальный путь
# Примеры: "TinyLlama/TinyLlama-1.1B-Chat-v1.0", "microsoft/Phi-3-mini-4k-instruct"
BASE_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Директория кэша моделей (опционально, по умолчанию ~/.cache/huggingface)
# HF_CACHE_DIR=~/.cache/huggingface

# Доверять remote code при загрузке моделей (используйте с осторожностью)
# TRUST_REMOTE_CODE=false

# -----------------------------------------------------------------------------
# Конфигурация LoRA
# -----------------------------------------------------------------------------

# LoRA rank (больше = больше параметров, по умолчанию: 8)
LORA_R=8

# LoRA alpha коэффициент масштабирования (по умолчанию: 16)
LORA_ALPHA=16

# LoRA dropout rate (по умолчанию: 0.1)
LORA_DROPOUT=0.1

# Target modules для LoRA (через запятую, по умолчанию: q_proj,k_proj,v_proj,o_proj)
LORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# Режим обучения bias (none, all, lora_only; по умолчанию: none)
LORA_BIAS=none

# Тип задачи для LoRA (CAUSAL_LM, SEQ_CLS, etc; по умолчанию: CAUSAL_LM)
LORA_TASK_TYPE=CAUSAL_LM

# -----------------------------------------------------------------------------
# Конфигурация обучения
# -----------------------------------------------------------------------------

# Директория для результатов (чекпоинты и логи)
OUTPUT_DIR=./outputs

# Директория для сохранения чекпоинтов
CHECKPOINT_DIR=./checkpoints

# Количество эпох обучения (по умолчанию: 3)
NUM_EPOCHS=3

# Batch size на одно устройство (по умолчанию: 4)
PER_DEVICE_BATCH_SIZE=4

# Шаги накопления градиента (по умолчанию: 4)
GRADIENT_ACCUMULATION_STEPS=4

# Learning rate (по умолчанию: 2e-4)
LEARNING_RATE=2e-4

# Warmup ratio (по умолчанию: 0.03)
WARMUP_RATIO=0.03

# Weight decay (по умолчанию: 0.01)
WEIGHT_DECAY=0.01

# Максимальная норма градиента для clipping (по умолчанию: 1.0)
MAX_GRAD_NORM=1.0

# Частота логирования в шагах (по умолчанию: 10)
LOGGING_STEPS=10

# Частота сохранения чекпоинтов в шагах (по умолчанию: 100)
SAVE_STEPS=100

# Стратегия evaluation (no, steps, epoch; по умолчанию: steps)
EVAL_STRATEGY=steps

# Частота evaluation в шагах (по умолчанию: 100)
EVAL_STEPS=100

# Загружать лучшую модель в конце (по умолчанию: true)
LOAD_BEST_MODEL_AT_END=true

# Максимальное количество сохраняемых чекпоинтов (по умолчанию: 3)
SAVE_TOTAL_LIMIT=3

# -----------------------------------------------------------------------------
# Конфигурация данных
# -----------------------------------------------------------------------------

# Путь к файлу с тренировочными данными (JSON, JSONL, CSV или HuggingFace dataset)
TRAIN_DATA_PATH=./data/train.jsonl

# Путь к файлу с валидационными данными (опционально)
# VALIDATION_DATA_PATH=./data/val.jsonl

# Имя колонки с текстом (по умолчанию: text)
TEXT_COLUMN=text

# Имя колонки с инструкцией для instruction tuning (опционально)
# INSTRUCTION_COLUMN=instruction

# Имя колонки с ответом для instruction tuning (опционально)
# RESPONSE_COLUMN=response

# Максимальная длина последовательности (по умолчанию: 512)
MAX_SEQ_LENGTH=512

# -----------------------------------------------------------------------------
# Оптимизация
# -----------------------------------------------------------------------------

# Использовать 8-bit Adam оптимизатор (по умолчанию: false)
# USE_8BIT_ADAM=false

# Использовать fp16 mixed precision (по умолчанию: true)
FP16=true

# Использовать bf16 mixed precision (по умолчанию: false, переопределяет fp16)
BF16=false

# Gradient checkpointing для экономии памяти (по умолчанию: true)
GRADIENT_CHECKPOINTING=true

# Максимальная память на GPU в MB (опционально, для multi-GPU)
# MAX_MEMORY_MB=

# -----------------------------------------------------------------------------
# Логирование и мониторинг
# -----------------------------------------------------------------------------

# Уровень логирования (DEBUG, INFO, WARNING, ERROR; по умолчанию: INFO)
LOG_LEVEL=INFO

# Путь к файлу логов (опционально)
LOG_FILE=./logs/training.log

# Имя проекта в Weights & Biases (опционально, отключить пустым значением)
WANDB_PROJECT=llm-fine-tuning

# API ключ для Weights & Biases (опционально)
# WANDB_API_KEY=

# Директория для TensorBoard логов (опционально)
# TENSORBOARD_DIR=./logs/tensorboard

# -----------------------------------------------------------------------------
# Конфигурация инференса
# -----------------------------------------------------------------------------

# Путь к дообученной модели или адаптеру для инференса
# INFERENCE_MODEL_PATH=./checkpoints/final

# Устройство для инференса (auto, cpu, cuda, cuda:0; по умолчанию: auto)
INFERENCE_DEVICE=auto

# Максимум новых токенов для генерации (по умолчанию: 256)
MAX_NEW_TOKENS=256

# Temperature для генерации (по умолчанию: 0.7)
TEMPERATURE=0.7

# Top_p для генерации (по умолчанию: 0.9)
TOP_P=0.9

# Top_k для генерации (по умолчанию: 50)
TOP_K=50

# Repetition penalty (по умолчанию: 1.0)
REPETITION_PENALTY=1.0

# -----------------------------------------------------------------------------
# Расширенная конфигурация
# -----------------------------------------------------------------------------

# Seed для воспроизводимости (по умолчанию: 42)
RANDOM_SEED=42

# Количество workers для DataLoader (по умолчанию: 4)
DATALOADER_NUM_WORKERS=4

# Удалять неиспользуемые колонки из датасета (по умолчанию: true)
REMOVE_UNUSED_COLUMNS=true

# Группировать тексты по длине для эффективности (по умолчанию: true)
GROUP_BY_LENGTH=true

# Использовать packing для эффективного обучения (по умолчанию: false)
USE_PACKING=false
